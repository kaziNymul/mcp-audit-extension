        </mxCell>

        <!-- Step 3: Scan Request -->
        <mxCell id="s3" value="&lt;b&gt;3. Scan Request&lt;/b&gt;&lt;br&gt;&lt;br&gt;PII detector scans&lt;br&gt;all parameters for&lt;br&gt;confidential data" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="120" width="160" height="120" as="geometry"/>
        </mxCell>

        <!-- Step 4a: Block -->
        <mxCell id="s4a" value="&lt;b&gt;4a. BLOCK&lt;/b&gt;&lt;br&gt;&lt;br&gt;PII detected →&lt;br&gt;Return error to IDE&lt;br&gt;&lt;b&gt;Data never sent&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e74c3c;fontColor=#ffffff;strokeColor=#c0392b;strokeWidth=2;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="310" width="160" height="120" as="geometry"/>
        </mxCell>

        <!-- Step 4b: Allow -->
        <mxCell id="s4b" value="&lt;b&gt;4b. Forward&lt;/b&gt;&lt;br&gt;&lt;br&gt;Clean request →&lt;br&gt;Send to real&lt;br&gt;MCP server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#27ae60;fontColor=#ffffff;strokeColor=#1e8449;strokeWidth=2;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="120" width="160" height="120" as="geometry"/>
        </mxCell>

        <!-- Step 5: Response -->
        <mxCell id="s5" value="&lt;b&gt;5. Scan Response&lt;/b&gt;&lt;br&gt;&lt;br&gt;MCP server response&lt;br&gt;scanned for PII&lt;br&gt;Redacted if found" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="980" y="120" width="160" height="120" as="geometry"/>
        </mxCell>

        <!-- Step 6: Redact Logs -->
        <mxCell id="s6" value="&lt;b&gt;6. Redact Logs&lt;/b&gt;&lt;br&gt;&lt;br&gt;redactRecordForLog()&lt;br&gt;strips ALL remaining&lt;br&gt;PII from log record" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1210" y="120" width="160" height="120" as="geometry"/>
        </mxCell>

        <!-- Step 7: Forward -->
        <mxCell id="s7" value="&lt;b&gt;7. Forward Logs&lt;/b&gt;&lt;br&gt;&lt;br&gt;Sanitized records sent&lt;br&gt;to Splunk, Syslog,&lt;br&gt;or File destinations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1440" y="120" width="160" height="120" as="geometry"/>
        </mxCell>

